# Supabase (required for server to start)
# Copy to .env. Use either SUPABASE_ANON_KEY (read-only, fine for products) or SUPABASE_SERVICE_ROLE_KEY.
# Get keys: Supabase dashboard → Jacks Quote App → Settings → API
#
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth (required for saved diagrams). Get from Supabase → Settings → API → JWT Secret
# SUPABASE_JWT_SECRET=your-jwt-secret

# ServiceM8 OAuth 2.0 (for internal use). Get from ServiceM8 Store Connect.
# SERVICEM8_APP_ID=your_app_id
# SERVICEM8_APP_SECRET=your_app_secret
# APP_BASE_URL=https://quote-app-production-7897.up.railway.app  # OAuth callback base (Railway production URL)
# Note: ServiceM8 Store Connect UI doesn't allow entering redirect URL.
# For internal use: redirect_uri is omitted from authorize request (optional per docs).
# redirect_uri is still required in token exchange and uses APP_BASE_URL + /api/servicem8/oauth/callback.
# When set, this user's ServiceM8 connection is used for all app users; only this user can connect/disconnect.
# Use COMPANY_EMAIL (resolved to user id) or COMPANY_USER_ID (Supabase auth UUID). Prefer COMPANY_EMAIL.
# SERVICEM8_COMPANY_EMAIL=jack@clearstreamguttering.co.nz
# SERVICEM8_COMPANY_USER_ID=your-supabase-auth-user-uuid

# PWA rollout: enabled by default. Set false to disable (no service worker, no install prompt).
# PWA_ENABLED=true

# Super admin: one user (by email) who cannot be modified or removed in User Permissions.
# That user must have role admin in public.profiles. Optional.
# SUPER_ADMIN_EMAIL=jack@clearstreamguttering.co.nz

# Do not commit .env. It is listed in .gitignore.
